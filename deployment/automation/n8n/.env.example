# GenuineStack n8n automation — environment template
# Copy to .env before first deploy: cp .env.example .env

# Public URL n8n registers webhooks against (no trailing slash)
# Local VPS:  http://127.0.0.1:5678
# Production: https://automation.genuinestack.com
N8N_WEBHOOK_URL=http://127.0.0.1:5678

# n8n UI basic auth (recommended for production)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-on-first-deploy

# Timezone
GENERIC_TIMEZONE=Asia/Tokyo
TZ=Asia/Tokyo

# Slack incoming webhook for human escalation alerts
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Optional: external ticket API (leave empty to use built-in mock ticket response)
TICKET_API_URL=

# Optional: ticket API auth header value
TICKET_API_TOKEN=
