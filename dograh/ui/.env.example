BACKEND_URL=http://api:8000

# Browser API base URL — used only for local dev (UI :3010, API :8000).
# In production, the UI uses window.location.origin (e.g. https://voice.genuinestack.com).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

NEXT_PUBLIC_NODE_ENV=development

