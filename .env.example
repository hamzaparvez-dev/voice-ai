# GenuineStack Japan — Environment Configuration
# Copy to dograh/.env before deployment

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
PUBLIC_HOST=localhost
BACKEND_API_ENDPOINT=http://localhost:8000
TURN_HOST=localhost

# ---------------------------------------------------------------------------
# Telemetry (disable for enterprise/APPI compliance)
# ---------------------------------------------------------------------------
ENABLE_TELEMETRY=false

# ---------------------------------------------------------------------------
# Secrets (generate with: openssl rand -hex 32)
# ---------------------------------------------------------------------------
OSS_JWT_SECRET=change-me-to-a-long-random-secret
POSTGRES_PASSWORD=change-me-to-a-strong-password
REDIS_PASSWORD=change-me-to-a-strong-password
MINIO_ROOT_USER=dograh
MINIO_ROOT_PASSWORD=change-me-to-a-strong-password

# ---------------------------------------------------------------------------
# Scaling
# ---------------------------------------------------------------------------
FASTAPI_WORKERS=4

# ---------------------------------------------------------------------------
# Optional: Bring Your Own Keys (BYOK)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# DEEPGRAM_API_KEY=...
# ELEVENLABS_API_KEY=...

# ---------------------------------------------------------------------------
# Production (Hostinger KVM2) — uncomment and set
# ---------------------------------------------------------------------------
# PUBLIC_HOST=your-domain.com
# BACKEND_API_ENDPOINT=https://your-domain.com
# TURN_HOST=your-domain.com
# TURN_SECRET=change-me-to-a-long-random-secret
